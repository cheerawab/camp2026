---
import { Image } from "astro:assets";
import MaterialSymbolsPlayCircleOutlineRounded from "~icons/material-symbols/play-circle-outline-rounded";

import siteConfig from "@/data/site.json";

const { studentComment } = siteConfig;
---

<div class="bg-background relative overflow-hidden py-5">
	<!-- 背景跑馬燈 -->
	<div class="pointer-events-none absolute inset-0 flex flex-col justify-around opacity-15">
		{
			Array.from({ length: studentComment.bgMarquee.repeatRows }, (_, i) => (
				<div class="marquee-row flex w-max" style={`animation-duration: ${9 + i * 0.9}s; animation-delay: ${-((i + 1) * 3) % 9}s`}>
					{[0, 1].map(() => (
						<span class="shrink-0 text-4xl font-bold whitespace-nowrap">{studentComment.bgMarquee.text.repeat(10)}&nbsp;</span>
					))}
				</div>
			))
		}
	</div>

	<!-- 前景內容 -->
	<div class="relative z-10">
		<h2 class="mb-2 text-center text-5xl font-black">聽聽往年學員怎麼說的</h2>

		<!-- 固定留言 -->
		<div class="mx-auto my-5 grid grid-cols-1 gap-x-4 gap-y-2 sm:grid-cols-2 md:w-[80%] lg:grid-cols-3">
			{
				studentComment.comments.map(c => (
					<div class="bg-foreground text-background w-full snap-start snap-always rounded-lg sm:w-fit">
						<div class:list={["flex items-center rounded-t-lg px-4 py-2", `bg-${c.color}`]}>
							<Image src="https://placehold.co/70x70" alt="Student's pfp" height="70" width="70" class="mr-5 rounded-full" />
							<p class="text-2xl font-bold">{c.name}</p>
							<div />
						</div>
						<p class="px-4 py-2 text-[16px]">{c.comment}</p>
					</div>
				))
			}
		</div>

		<!-- 影片跑馬燈 -->
		<div class="marquee-container my-5 flex w-full overflow-hidden">
			<div class="marquee-track flex w-max gap-4">
				<div class="flex shrink-0 gap-4">
					{
						studentComment.video.map(v => (
							<div class:list={["video-card bg-foreground aspect-video max-h-50 w-75 cursor-pointer rounded-lg", `bg-[url(${v.cover})]`]} data-url={v.url}>
								<div class="flex h-full w-full items-center justify-center">
									<MaterialSymbolsPlayCircleOutlineRounded class="text-background text-2xl" />
								</div>

								<p class="text-background relative bottom-12 text-center text-4xl font-bold">{v.label}</p>
							</div>
						))
					}
				</div>
				<div class="flex shrink-0 gap-4">
					{
						studentComment.video.map(v => (
							<div class:list={["video-card bg-foreground aspect-video max-h-50 w-75 cursor-pointer rounded-lg", `bg-[url(${v.cover})]`]} data-url={v.url}>
								<div class="flex h-full w-full items-center justify-center">
									<MaterialSymbolsPlayCircleOutlineRounded class="text-background text-2xl" />
								</div>

								<p class="text-background relative bottom-13 text-center text-4xl font-bold">{v.label}</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>

	<!-- 學員訪談 YouTube 影片 popup -->
	<dialog id="comment-dialog" class="m-auto w-full max-w-3xl rounded-xl p-0 shadow-xl">
		<div class="aspect-video w-full">
			<iframe id="comment-iframe" class="h-full w-full rounded-xl" title="YouTube video player" allow="autoplay; encrypted-media;" src="" referrerpolicy="strict-origin-when-cross-origin"></iframe>
		</div>
	</dialog>

	<!-- 防止顏色被 TailwindCSS tree shaking 掉 -->
	<div class="bg-green h-0 w-0"></div>
	<div class="bg-dark-green h-0 w-0"></div>
	<div class="bg-blue h-0 w-0"></div>
	<div class="bg-sky-blue h-0 w-0"></div>
	<div class="bg-soft-blue h-0 w-0"></div>
	<div class="bg-orange h-0 w-0"></div>
</div>

<style>
	@keyframes marquee {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	/* 影片跑馬燈 */
	.marquee-track {
		animation: marquee 20s linear infinite;
	}

	.marquee-container:hover .marquee-track {
		animation-play-state: paused;
	}

	/* 背景文字跑馬燈 */
	.marquee-row {
		animation: marquee 10s linear infinite;
	}
</style>

<script>
	const dialog = document.getElementById("comment-dialog") as HTMLDialogElement;
	const iframe = document.getElementById("comment-iframe") as HTMLIFrameElement;

	document.querySelectorAll<HTMLElement>(".video-card").forEach(card => {
		card.addEventListener("click", () => {
			const url = card.dataset.url;
			if (!url) return;
			iframe.src = url;
			dialog.showModal();
		});
	});

	dialog.addEventListener("click", e => {
		if (e.target === dialog) closeModal();
	});

	function closeModal() {
		dialog.close();
		iframe.src = "";
	}
</script>
